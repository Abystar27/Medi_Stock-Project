doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title MediStock
    link(rel="stylesheet", href="/CSS/style.css")
    //- link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css")

    script(src="https://kit.fontawesome.com/328bbfc4a9.js", crossorigin="anonymous")
  body
    .nav
    .headNav
      a(href="/dashboard")
        .logo
          img#logo(src="/Images/medi1.png")
          h1 MediStock
      ul.navLinks
        li: a(href="/inventory") Inventory
        li: a(href="/activitylog") History
        li: a(href="/expiringitems") Alert
      .rightNav
        a.userProfile(href="/adminprofile")
          i.fa-solid.fa-user
          p Profile
        #menu
          i.fa-solid.fa-bars
    .mobilenav      
      ul.navlink
        li: a(href="/inventory") Inventory
        li: a(href="/activitylog") History
        li: a(href="/expiringitems") Alert
    block content
    block scripts 
    script(src="/script.js")